{
  "name": "fintrack",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --mac"
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "react": "^18",
    "react-chartjs-2": "^5",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4",
    "concurrently": "^8",
    "electron": "^28",
    "electron-builder": "^24",
    "vite": "^5",
    "wait-on": "^7"
  },
  "build": {
    "appId": "com.fintrack.app",
    "productName": "FinTrack",
    "mac": { "target": "dmg" },
    "files": ["dist/**", "electron/**"],
    "extraResources": [{ "from": "data", "to": "data" }]
  }
}
